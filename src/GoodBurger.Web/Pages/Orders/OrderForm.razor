@inject IMenuService MenuService

@if (_loadingMenu)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudGrid>
        <MudItem xs="12">
            <MudSelect T="Guid"
                       Label="Sanduíche *"
                       @bind-Value="Request.SandwichItemId"
                       @bind-Value:after="UpdatePreview"
                       Variant="Variant.Outlined"
                       Required="true"
                       HelperText="Obrigatório">
                @foreach (var item in _sandwiches)
                {
                    <MudSelectItem Value="@item.Id">@item.Name — @item.FormattedPrice</MudSelectItem>
                }
            </MudSelect>
        </MudItem>

        <MudItem xs="12" sm="6">
            <MudSelect T="Guid?"
                       Label="Batata Frita"
                       @bind-Value="Request.FriesItemId"
                       @bind-Value:after="UpdatePreview"
                       Variant="Variant.Outlined"
                       Clearable="true"
                       HelperText="Opcional">
                @foreach (var item in _fries)
                {
                    <MudSelectItem Value="@((Guid?)item.Id)">@item.Name — @item.FormattedPrice</MudSelectItem>
                }
            </MudSelect>
        </MudItem>

        <MudItem xs="12" sm="6">
            <MudSelect T="Guid?"
                       Label="Bebida"
                       @bind-Value="Request.DrinkItemId"
                       @bind-Value:after="UpdatePreview"
                       Variant="Variant.Outlined"
                       Clearable="true"
                       HelperText="Opcional">
                @foreach (var item in _drinks)
                {
                    <MudSelectItem Value="@((Guid?)item.Id)">@item.Name — @item.FormattedPrice</MudSelectItem>
                }
            </MudSelect>
        </MudItem>

        <MudItem xs="12">
            <MudDivider Class="my-2" />
            <MudText Typo="Typo.subtitle1" Class="mb-2">Resumo do Pedido</MudText>
            <MudSimpleTable Dense="true" Elevation="0">
                <tbody>
                    <tr>
                        <td>Subtotal</td>
                        <td align="right">@_preview.Subtotal.ToString("C2", _ptBr)</td>
                    </tr>
                    @if (_preview.DiscountPercentage > 0)
                    {
                        <tr style="color: green;">
                            <td>Desconto (@_preview.DiscountPercentage.ToString("0")%)</td>
                            <td align="right">- @_preview.DiscountAmount.ToString("C2", _ptBr)</td>
                        </tr>
                    }
                    <tr style="font-weight:bold;">
                        <td>Total</td>
                        <td align="right">@_preview.Total.ToString("C2", _ptBr)</td>
                    </tr>
                </tbody>
            </MudSimpleTable>
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter, EditorRequired] public CreateOrderRequest Request { get; set; } = new();

    private readonly System.Globalization.CultureInfo _ptBr = new("pt-BR");

    private bool _loadingMenu = true;
    private List<MenuItemModel> _sandwiches = new();
    private List<MenuItemModel> _fries = new();
    private List<MenuItemModel> _drinks = new();

    private (decimal Subtotal, decimal DiscountPercentage, decimal DiscountAmount, decimal Total) _preview;

    protected override async Task OnInitializedAsync()
    {
        var items = await MenuService.GetMenuAsync();
        _sandwiches  = items.Where(i => i.Category == "Sanduiche").ToList();
        _fries       = items.Where(i => i.Category == "Batata").ToList();
        _drinks      = items.Where(i => i.Category == "Bebida").ToList();
        _loadingMenu = false;
        UpdatePreview();
    }

    protected override void OnParametersSet() => UpdatePreview();

    private void UpdatePreview()
    {
        var sandwich = _sandwiches.FirstOrDefault(i => i.Id == Request.SandwichItemId);
        var fries = Request.FriesItemId.HasValue
            ? _fries.FirstOrDefault(i => i.Id == Request.FriesItemId.Value)
            : null;
        var drink = Request.DrinkItemId.HasValue
            ? _drinks.FirstOrDefault(i => i.Id == Request.DrinkItemId.Value)
            : null;

        var subtotal = (sandwich?.Price ?? 0m) + (fries?.Price ?? 0m) + (drink?.Price ?? 0m);

        decimal discountPercentage = (fries is not null, drink is not null) switch
        {
            (true,  true)  => 20m,
            (false, true)  => 15m,
            (true,  false) => 10m,
            _              => 0m
        };

        var discountAmount = Math.Round(subtotal * discountPercentage / 100m, 2);
        _preview = (subtotal, discountPercentage, discountAmount, subtotal - discountAmount);
    }
}
