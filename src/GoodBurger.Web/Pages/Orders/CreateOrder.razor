@page "/orders/new"
@attribute [Authorize]
@inject IOrderService OrderService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Novo Pedido — Good Burger</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">➕ Novo Pedido</MudText>

<MudPaper Elevation="2" Class="pa-4">
    <OrderForm Request="_request" />

    <MudStack Row="true" Justify="Justify.FlexEnd" Class="mt-4" Spacing="2">
        <MudButton Variant="Variant.Outlined"
                   OnClick="@(() => Navigation.NavigateTo("/orders"))"
                   Disabled="_saving">
            Cancelar
        </MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   OnClick="HandleSubmit"
                   Disabled="_saving">
            @if (_saving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <span>Salvando...</span>
            }
            else
            {
                <span>Criar Pedido</span>
            }
        </MudButton>
    </MudStack>
</MudPaper>

@code {
    private readonly CreateOrderRequest _request = new();
    private bool _saving;

    private async Task HandleSubmit()
    {
        if (_request.SandwichItemId == Guid.Empty)
        {
            Snackbar.Add("Selecione um sanduíche para continuar.", Severity.Warning);
            return;
        }

        _saving = true;
        var (order, error) = await OrderService.CreateOrderAsync(_request);
        _saving = false;

        if (order is not null)
        {
            Snackbar.Add("Pedido criado com sucesso!", Severity.Success);
            Navigation.NavigateTo("/orders");
        }
        else
        {
            Snackbar.Add(error ?? "Erro ao criar pedido.", Severity.Error);
        }
    }
}
