@page "/orders"
@attribute [Authorize]
@inject IOrderService OrderService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Pedidos — Good Burger</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h5">🛒 Pedidos</MudText>
    <MudSpacer />
    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add"
               OnClick="@(() => Navigation.NavigateTo("/orders/new"))">
        Novo Pedido
    </MudButton>
</MudStack>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (!_orders.Any())
{
    <MudAlert Severity="Severity.Info">
        Nenhum pedido cadastrado. Clique em "Novo Pedido" para começar.
    </MudAlert>
}
else
{
    <MudTable Items="@_orders" Dense="false" Hover="true" Elevation="2" T="OrderResponse">
        <HeaderContent>
            <MudTh>Itens</MudTh>
            <MudTh Style="text-align:right">Subtotal</MudTh>
            <MudTh Style="text-align:right">Desconto</MudTh>
            <MudTh Style="text-align:right">Total</MudTh>
            <MudTh Style="text-align:right">Data</MudTh>
            <MudTh Style="text-align:center">Ações</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Itens">@context.ItemsSummary</MudTd>
            <MudTd DataLabel="Subtotal" Style="text-align:right">@context.FormattedSubtotal</MudTd>
            <MudTd DataLabel="Desconto" Style="text-align:right">
                @if (context.DiscountPercentage > 0)
                {
                    <MudChip T="string" Color="Color.Success" Size="Size.Small">
                        -@context.DiscountPercentage.ToString("0")% (@context.FormattedDiscount)
                    </MudChip>
                }
                else
                {
                    <MudText>—</MudText>
                }
            </MudTd>
            <MudTd DataLabel="Total" Style="text-align:right">
                <MudText Color="Color.Primary"><strong>@context.FormattedTotal</strong></MudText>
            </MudTd>
            <MudTd DataLabel="Data" Style="text-align:right">
                @context.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
            </MudTd>
            <MudTd DataLabel="Ações" Style="text-align:center">
                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                               Color="Color.Primary"
                               Size="Size.Small"
                               OnClick="@(() => Navigation.NavigateTo($"/orders/{context.Id}/edit"))"
                               title="Editar" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                               Color="Color.Error"
                               Size="Size.Small"
                               OnClick="@(() => ConfirmDelete(context))"
                               title="Excluir" />
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private bool _loading = true;
    private List<OrderResponse> _orders = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadOrders();
    }

    private async Task LoadOrders()
    {
        _loading = true;
        _orders = await OrderService.GetOrdersAsync();
        _loading = false;
    }

    private async Task ConfirmDelete(OrderResponse order)
    {
        var options = new DialogOptions { CloseOnEscapeKey = true };
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { x => x.ContentText, $"Deseja remover o pedido com {order.ItemsSummary}?" },
            { x => x.ButtonText, "Remover" },
            { x => x.Color, Color.Error }
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Confirmar exclusão", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            var (success, error) = await OrderService.DeleteOrderAsync(order.Id);
            if (success)
            {
                Snackbar.Add("Pedido removido com sucesso.", Severity.Success);
                await LoadOrders();
            }
            else
            {
                Snackbar.Add(error ?? "Erro ao remover pedido.", Severity.Error);
            }
        }
    }
}
