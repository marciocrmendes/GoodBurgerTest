@page "/orders/{Id:guid}/edit"
@attribute [Authorize]
@inject IOrderService OrderService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Editar Pedido — Good Burger</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">✏️ Editar Pedido</MudText>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_notFound)
{
    <MudAlert Severity="Severity.Error">Pedido não encontrado.</MudAlert>
    <MudButton Class="mt-2" OnClick="@(() => Navigation.NavigateTo("/orders"))">
        Voltar para pedidos
    </MudButton>
}
else
{
    <MudPaper Elevation="2" Class="pa-4">
        <OrderForm Request="_request" />

        <MudStack Row="true" Justify="Justify.FlexEnd" Class="mt-4" Spacing="2">
            <MudButton Variant="Variant.Outlined"
                       OnClick="@(() => Navigation.NavigateTo("/orders"))"
                       Disabled="_saving">
                Cancelar
            </MudButton>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="HandleSubmit"
                       Disabled="_saving">
                @if (_saving)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    <span>Salvando...</span>
                }
                else
                {
                    <span>Salvar Alterações</span>
                }
            </MudButton>
        </MudStack>
    </MudPaper>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private readonly CreateOrderRequest _request = new();
    private bool _loading = true;
    private bool _saving;
    private bool _notFound;

    protected override async Task OnInitializedAsync()
    {
        var order = await OrderService.GetOrderByIdAsync(Id);
        if (order is null)
        {
            _notFound = true;
        }
        else
        {
            _request.SandwichItemId = order.SandwichItem.Id;
            _request.FriesItemId    = order.FriesItem?.Id;
            _request.DrinkItemId    = order.DrinkItem?.Id;
        }
        _loading = false;
    }

    private async Task HandleSubmit()
    {
        if (_request.SandwichItemId == Guid.Empty)
        {
            Snackbar.Add("Selecione um sanduíche para continuar.", Severity.Warning);
            return;
        }

        _saving = true;
        var updateRequest = new UpdateOrderRequest
        {
            SandwichItemId = _request.SandwichItemId,
            FriesItemId    = _request.FriesItemId,
            DrinkItemId    = _request.DrinkItemId
        };
        var (order, error) = await OrderService.UpdateOrderAsync(Id, updateRequest);
        _saving = false;

        if (order is not null)
        {
            Snackbar.Add("Pedido atualizado com sucesso!", Severity.Success);
            Navigation.NavigateTo("/orders");
        }
        else
        {
            Snackbar.Add(error ?? "Erro ao atualizar pedido.", Severity.Error);
        }
    }
}
