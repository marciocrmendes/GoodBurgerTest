@page "/login"
@layout EmptyLayout
@inject AuthService AuthService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Login — Good Burger</PageTitle>

<MudGrid Justify="Justify.Center" Style="min-height: 100vh; align-items: center;">
    <MudItem xs="12" sm="8" md="4">
        <MudCard Elevation="4">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h5" Align="Align.Center">🍔 Good Burger</MudText>
                    <MudText Typo="Typo.subtitle2" Align="Align.Center" Color="Color.Secondary">
                        Sistema de Pedidos
                    </MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudTextField @bind-Value="_request.Username"
                              Label="Usuário"
                              Variant="Variant.Outlined"
                              FullWidth="true"
                              Class="mb-3"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Person"
                              Disabled="_loading" />

                <MudTextField @bind-Value="_request.Password"
                              Label="Senha"
                              Variant="Variant.Outlined"
                              FullWidth="true"
                              InputType="@_passwordInputType"
                              Adornment="Adornment.End"
                              AdornmentIcon="@_passwordIcon"
                              OnAdornmentClick="TogglePasswordVisibility"
                              Disabled="_loading" />
            </MudCardContent>
            <MudCardActions Class="pa-4">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           OnClick="HandleLogin"
                           Disabled="_loading">
                    @if (_loading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        <span>Entrando...</span>
                    }
                    else
                    {
                        <span>Entrar</span>
                    }
                </MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    private readonly LoginRequest _request = new();
    private bool _loading;
    private bool _showPassword;

    private InputType _passwordInputType => _showPassword ? InputType.Text : InputType.Password;
    private string _passwordIcon => _showPassword
        ? Icons.Material.Filled.VisibilityOff
        : Icons.Material.Filled.Visibility;

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    private void TogglePasswordVisibility() => _showPassword = !_showPassword;

    private async Task HandleLogin()
    {
        if (string.IsNullOrWhiteSpace(_request.Username) || string.IsNullOrWhiteSpace(_request.Password))
        {
            Snackbar.Add("Preencha usuário e senha.", Severity.Warning);
            return;
        }

        _loading = true;
        var (success, error) = await AuthService.LoginAsync(_request);
        _loading = false;

        if (success)
        {
            Snackbar.Add("Login realizado com sucesso!", Severity.Success);
            Navigation.NavigateTo(ReturnUrl ?? "/orders");
        }
        else
        {
            Snackbar.Add(error ?? "Erro ao fazer login.", Severity.Error);
        }
    }
}
