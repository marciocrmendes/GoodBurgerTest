{
  "ConnectionStrings": {
    // Como aqui é apenas um exemplo, a chave secreta do JWT está hardcoded
    // Em um ambiente de produção deve ser armazenada de forma segura
    "goodburger-db": "Host=localhost;Database=goodburger;Username=postgres;Password=postgres"
  },
  "Jwt": {
    // Mesma coisa
    "Secret": "GoodBurger_SuperSecret_JWT_Key_2024_!@#",
    "Issuer": "GoodBurger",
    "Audience": "GoodBurgerClients",
    "ExpiresInMinutes": 480
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "Application",
      "Environment",
      "MachineName"
    ]
  },
  "AllowedHosts": "*"
}
